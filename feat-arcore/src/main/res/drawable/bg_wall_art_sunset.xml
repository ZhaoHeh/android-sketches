<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#2A3559"
                android:startColor="#F6C16C" />
            <corners android:radius="12dp" />
        </shape>
    </item>
    <item android:bottom="24dp" android:left="18dp" android:right="18dp" android:top="92dp">
        <shape android:shape="oval">
            <solid android:color="#F1E0B1" />
        </shape>
    </item>
    <item android:bottom="0dp" android:left="0dp" android:right="0dp" android:top="120dp">
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:endColor="#C06B4B"
                android:startColor="#5E2D24" />
            <corners
                android:bottomLeftRadius="12dp"
                android:bottomRightRadius="12dp" />
        </shape>
    </item>
</layer-list>
