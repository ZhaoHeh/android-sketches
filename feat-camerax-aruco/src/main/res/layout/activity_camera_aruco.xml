<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".CameraArucoActivity">

    <FrameLayout
        android:id="@+id/previewContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#000000"
        app:layout_constraintBottom_toTopOf="@id/infoPanel"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.camera.view.PreviewView
            android:id="@+id/previewView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <dev.hehe.sketch.feat.cameraxaruco.ArucoOverlayView
            android:id="@+id/overlayView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/previewStatusView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:background="#88000000"
            android:paddingHorizontal="16dp"
            android:paddingVertical="10dp"
            android:text="@string/camera_aruco_status_initializing"
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
            android:textColor="#FFFFFF"
            tools:text="正在启动相机..." />

    </FrameLayout>

    <ScrollView
        android:id="@+id/infoPanel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#000000"
        android:elevation="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp">

            <TextView
                android:id="@+id/infoTitleView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/camera_aruco_info_title"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/detectionStatusLabelView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_info_status_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="#A6A6A6" />

            <TextView
                android:id="@+id/detectionStatusValueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/camera_aruco_status_initializing"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="#7EE787"
                tools:text="正在识别 arUco" />

            <TextView
                android:id="@+id/detectionCountLabelView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_info_count_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="#A6A6A6" />

            <TextView
                android:id="@+id/detectionCountValueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/detectionIdsLabelView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_info_ids_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="#A6A6A6" />

            <TextView
                android:id="@+id/detectionIdsValueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/camera_aruco_ids_empty"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="#FFFFFF"
                tools:text="12, 18" />

            <TextView
                android:id="@+id/detectionLatencyLabelView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_info_latency_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="#A6A6A6" />

            <TextView
                android:id="@+id/detectionLatencyValueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/camera_aruco_latency_empty"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="#FFFFFF"
                tools:text="28 ms" />

            <TextView
                android:id="@+id/recordingTitleView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/camera_aruco_recording_title"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Subtitle1"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/recordingStatusLabelView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_recording_status_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="#A6A6A6" />

            <TextView
                android:id="@+id/recordingStatusValueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/camera_aruco_recording_status_idle"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="#FFB86C" />

            <TextView
                android:id="@+id/recordingQualityLabelView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_recording_quality_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="#A6A6A6" />

            <TextView
                android:id="@+id/recordingQualityValueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="--"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/recordingResolutionLabelView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_recording_resolution_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="#A6A6A6" />

            <TextView
                android:id="@+id/recordingResolutionValueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="--"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/recordingDurationLabelView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_recording_duration_label"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Caption"
                android:textColor="#A6A6A6" />

            <TextView
                android:id="@+id/recordingDurationValueView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="00:00"
                android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                android:textColor="#FFFFFF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/startRecordingButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/camera_aruco_action_start_recording" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/stopRecordingButton"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="@string/camera_aruco_action_stop_recording" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/openLatestVideoButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/camera_aruco_action_open_latest_video" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
