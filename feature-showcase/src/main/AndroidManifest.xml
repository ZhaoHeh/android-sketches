<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="dev.hehe.sketch.feature.showcase">

    <application>
        <activity
            android:name=".ShowcaseActivity"
            android:exported="false">
            <intent-filter>
                <action android:name="dev.hehe.sketch.action.SKETCH_ENTRY" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>

            <meta-data
                android:name="dev.hehe.sketch.entry.TITLE"
                android:value="Showcase 示例页" />
            <meta-data
                android:name="dev.hehe.sketch.entry.SUMMARY"
                android:value="一个用于演示的功能模块，验证通过 manifest 注册的 Activity 可以自动出现在应用首页。" />
            <meta-data
                android:name="dev.hehe.sketch.entry.ORDER"
                android:value="10" />
            <meta-data
                android:name="dev.hehe.sketch.entry.MODULE"
                android:value="feature-showcase" />
        </activity>
    </application>

</manifest>
